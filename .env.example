# =============================================================================
# ClinicDx Engine — Environment Configuration
# =============================================================================
# Copy to .env before first launch:  cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# ── HuggingFace (auto-download on first start) ──────────────────────────────
# Only needed if repos are gated. ClinicDx1/ClinicDx is public.
HF_TOKEN=
HF_MODEL_REPO=ClinicDx1/ClinicDx
HF_KB_REPO=ClinicDx1/ClinicDx

# ── Engine port (exposed to host) ───────────────────────────────────────────
ENGINE_PORT=8321

# ── Model server ────────────────────────────────────────────────────────────
N_GPU_LAYERS=999
MODEL_CTX=8192
MODEL_PARALLEL=1
MODEL_THREADS=8

# ── Knowledge Base ──────────────────────────────────────────────────────────
KB_SEARCH_MODE=rrf
KB_K=5
KB_SNIPPET_CHARS=15000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# =============================================================================
# Full-stack only (docker-compose.full.yml) — ignored by engine-only mode
# =============================================================================

# OpenMRS backend (enables /scribe/manifest and /scribe/confirm endpoints)
# OPENMRS_URL=https://172.18.0.1/openmrs
# OPENMRS_USER=admin
# OPENMRS_PASSWORD=Admin123

# SSL certificates for nginx
# SSL_CERT_PATH=./certs/server.crt
# SSL_KEY_PATH=./certs/server.key
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
